<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <Color x:Key="SurfaceBaseColor">#F7F9FB</Color>
    <Color x:Key="SurfaceRaisedColor">#FFFFFF</Color>
    <Color x:Key="SurfaceElevatedColor">#FFFFFF</Color>
    <Color x:Key="SurfaceOverlayColor">#EEF2F6</Color>

    <Color x:Key="ForegroundPrimaryColor">#1F2933</Color>
    <Color x:Key="ForegroundSecondaryColor">#52606D</Color>
    <Color x:Key="ForegroundMutedColor">#7B8794</Color>

    <Color x:Key="StrokeSubtleColor">#E4E7EB</Color>
    <Color x:Key="StrokeStrongColor">#CBD2D9</Color>

    <Color x:Key="AccentPrimaryColor">#0EA5A4</Color>
    <Color x:Key="AccentSecondaryColor">#0284C7</Color>
    <Color x:Key="AccentWarningColor">#D97706</Color>
    <Color x:Key="AccentDangerColor">#DC2626</Color>
    <Color x:Key="AccentSuccessColor">#16A34A</Color>

    <SolidColorBrush x:Key="SurfaceBaseBrush" Color="{StaticResource SurfaceBaseColor}" />
    <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="{StaticResource SurfaceRaisedColor}" />
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="{StaticResource SurfaceElevatedColor}" />
    <SolidColorBrush x:Key="SurfaceOverlayBrush" Color="{StaticResource SurfaceOverlayColor}" />
    <SolidColorBrush x:Key="ForegroundPrimaryBrush" Color="{StaticResource ForegroundPrimaryColor}" />
    <SolidColorBrush x:Key="ForegroundSecondaryBrush" Color="{StaticResource ForegroundSecondaryColor}" />
    <SolidColorBrush x:Key="ForegroundMutedBrush" Color="{StaticResource ForegroundMutedColor}" />
    <SolidColorBrush x:Key="StrokeSubtleBrush" Color="{StaticResource StrokeSubtleColor}" />
    <SolidColorBrush x:Key="StrokeStrongBrush" Color="{StaticResource StrokeStrongColor}" />
    <SolidColorBrush x:Key="AccentPrimaryBrush" Color="{StaticResource AccentPrimaryColor}" />
    <SolidColorBrush x:Key="AccentSecondaryBrush" Color="{StaticResource AccentSecondaryColor}" />
    <SolidColorBrush x:Key="AccentWarningBrush" Color="{StaticResource AccentWarningColor}" />
    <SolidColorBrush x:Key="AccentDangerBrush" Color="{StaticResource AccentDangerColor}" />
    <SolidColorBrush x:Key="AccentSuccessBrush" Color="{StaticResource AccentSuccessColor}" />

    <sys:Double x:Key="FontSizeDisplay">28</sys:Double>
    <sys:Double x:Key="FontSizeTitle">20</sys:Double>
    <sys:Double x:Key="FontSizeHeading">16</sys:Double>
    <sys:Double x:Key="FontSizeBody">13</sys:Double>
    <sys:Double x:Key="FontSizeCaption">11</sys:Double>

    <FontFamily x:Key="UiFontFamily">Segoe UI, San Francisco, Inter, Arial</FontFamily>
    <FontFamily x:Key="MonoFontFamily">Consolas, JetBrains Mono, Cascadia Code, Menlo</FontFamily>

</ResourceDictionary>
