<UserControl x:Class="DiscreteMathToolkit.App.Views.TreesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vmp="clr-namespace:DiscreteMathToolkit.App.ViewModels.Pages"
             xmlns:c="clr-namespace:DiscreteMathToolkit.App.Views.Controls"
             d:DataContext="{d:DesignInstance Type=vmp:TreesViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid Background="{DynamicResource SurfaceBaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="32,24,32,16" Orientation="Horizontal">
            <TextBlock Text="Trees" Style="{StaticResource DisplayTextStyle}" />
            <TextBlock Text="BST · Traversals · Reconstruction"
                       Foreground="{DynamicResource ForegroundSecondaryBrush}"
                       FontSize="{DynamicResource FontSizeBody}"
                       VerticalAlignment="Bottom"
                       Margin="16,0,0,8" />
        </StackPanel>

        <!-- Canvas + explanation -->
        <Border Grid.Row="1" Grid.Column="0"
                Style="{StaticResource CardStyle}"
                Margin="32,0,16,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <c:TreeCanvas x:Name="Canvas"
                                  RenderState="{Binding RenderState}"
                                  Width="{Binding RenderState.Width}"
                                  Height="{Binding RenderState.Height}" />
                </ScrollViewer>

                <Border Grid.Row="1"
                        Background="{DynamicResource SurfaceOverlayBrush}"
                        CornerRadius="6"
                        Padding="14,10"
                        Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="STEP" Style="{StaticResource CaptionTextStyle}" />
                        <TextBlock Text="{Binding Explanation}"
                                   FontSize="{DynamicResource FontSizeBody}"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Right side panel -->
        <ScrollViewer Grid.Row="1" Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      Margin="0,0,32,16">
            <StackPanel>
                <!-- TREE EDITOR -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="TREE EDITOR" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,8" />

                        <TextBlock Text="Build BST from sequence" Foreground="{DynamicResource ForegroundSecondaryBrush}" FontSize="{DynamicResource FontSizeCaption}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding BulkInsertText, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Content="Build BST" Command="{Binding BuildBstCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,8,0,0" />

                        <TextBlock Text="Insert single value" Foreground="{DynamicResource ForegroundSecondaryBrush}" FontSize="{DynamicResource FontSizeCaption}" Margin="0,16,0,4" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding SingleInsertValue, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1" Content="+" Width="36" Margin="6,0,0,0" Command="{Binding InsertOneCommand}" />
                        </Grid>

                        <TextBlock Text="Search / delete" Foreground="{DynamicResource ForegroundSecondaryBrush}" FontSize="{DynamicResource FontSizeCaption}" Margin="0,16,0,4" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding SearchOrDeleteValue, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1" Content="🔍" Width="36" Margin="6,0,0,0" Command="{Binding SearchCommand}" />
                            <Button Grid.Column="2" Content="✕" Width="36" Margin="6,0,0,0" Command="{Binding DeleteCommand}" />
                        </Grid>

                        <Button Content="Clear tree" Command="{Binding ClearTreeCommand}" Margin="0,12,0,0" />
                    </StackPanel>
                </Border>

                <!-- TRAVERSAL -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="TRAVERSAL" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,8" />
                        <ComboBox ItemsSource="{Binding Traversals}"
                                  SelectedItem="{Binding SelectedTraversal, Mode=TwoWay}" />
                        <Button Content="Run traversal" Command="{Binding RunTraversalCommand}"
                                Style="{StaticResource PrimaryButtonStyle}" Margin="0,8,0,8" />
                        <TextBlock Text="{Binding ResultSummary}" TextWrapping="Wrap"
                                   FontSize="{DynamicResource FontSizeCaption}"
                                   Foreground="{DynamicResource ForegroundSecondaryBrush}" />
                    </StackPanel>
                </Border>

                <!-- PLAYBACK -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="PLAYBACK" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,8" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="◀" Command="{Binding StepPreviousCommand}" Margin="0,0,4,0" />
                            <Button Grid.Column="1" Content="▶" Command="{Binding TogglePlayCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,4,0" />
                            <Button Grid.Column="2" Content="▶▶" Command="{Binding StepNextCommand}" Margin="0,0,4,0" />
                            <Button Grid.Column="3" Content="⟲" Command="{Binding ResetPlaybackCommand}" />
                        </Grid>
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Speed" VerticalAlignment="Center" Margin="0,0,8,0"
                                       Foreground="{DynamicResource ForegroundSecondaryBrush}" />
                            <Slider Grid.Column="1"
                                    Minimum="0.25" Maximum="4" Value="{Binding PlaybackSpeed, Mode=TwoWay}"
                                    TickFrequency="0.25" SmallChange="0.25" LargeChange="1"
                                    IsSnapToTickEnabled="True" Style="{StaticResource SliderStyle}" />
                        </Grid>
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="{DynamicResource ForegroundSecondaryBrush}"
                                   FontSize="{DynamicResource FontSizeCaption}">
                            <Run Text="Step " />
                            <Run Text="{Binding StepDisplayIndex, Mode=OneWay}" />
                            <Run Text=" of " />
                            <Run Text="{Binding TotalSteps, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- RECONSTRUCTION -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="RECONSTRUCT" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,8" />

                        <TextBlock Text="Pre-order" Foreground="{DynamicResource ForegroundSecondaryBrush}" FontSize="{DynamicResource FontSizeCaption}" Margin="0,0,0,2" />
                        <TextBox Text="{Binding ReconstructPreOrder, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="In-order" Foreground="{DynamicResource ForegroundSecondaryBrush}" FontSize="{DynamicResource FontSizeCaption}" Margin="0,8,0,2" />
                        <TextBox Text="{Binding ReconstructInOrder, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Post-order" Foreground="{DynamicResource ForegroundSecondaryBrush}" FontSize="{DynamicResource FontSizeCaption}" Margin="0,8,0,2" />
                        <TextBox Text="{Binding ReconstructPostOrder, UpdateSourceTrigger=PropertyChanged}" />

                        <Button Content="From Pre + In" Command="{Binding ReconstructFromPreInCommand}" Margin="0,12,0,0" />
                        <Button Content="From Post + In" Command="{Binding ReconstructFromPostInCommand}" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <!-- EXPORT -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="EXPORT" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,8" />
                        <Button Content="Export traversal…" Command="{Binding ExportTraversalCommand}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Status bar -->
        <Border Grid.Row="2" Grid.ColumnSpan="2"
                Background="{DynamicResource SurfaceRaisedBrush}"
                BorderBrush="{DynamicResource StrokeSubtleBrush}"
                BorderThickness="0,1,0,0"
                Padding="32,8">
            <TextBlock Text="{Binding StatusLine}"
                       Foreground="{DynamicResource ForegroundSecondaryBrush}"
                       FontSize="{DynamicResource FontSizeCaption}" />
        </Border>
    </Grid>
</UserControl>
