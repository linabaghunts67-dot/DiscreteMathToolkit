<Application x:Class="DiscreteMathToolkit.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DiscreteMathToolkit.App.ViewModels"
             xmlns:vmp="clr-namespace:DiscreteMathToolkit.App.ViewModels.Pages"
             xmlns:v="clr-namespace:DiscreteMathToolkit.App.Views"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/ColorsDark.xaml" />
                <ResourceDictionary Source="Themes/ControlStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                <v:DashboardView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vmp:GraphTheoryViewModel}">
                <v:GraphTheoryView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vmp:TreesViewModel}">
                <v:TreesView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vmp:LogicViewModel}">
                <v:LogicView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vmp:CombinatoricsViewModel}">
                <v:CombinatoricsView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vmp:NumberSystemsViewModel}">
                <v:NumberSystemsView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vmp:SetsRelationsViewModel}">
                <v:SetsRelationsView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vmp:SettingsViewModel}">
                <v:SettingsView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vmp:PlaceholderPageViewModel}">
                <v:PlaceholderView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
